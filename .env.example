# Smart Takaful & Consultation System — local env template
# Copy to `.env` and fill in real values. The `.env` file is gitignored.

# --- Spring profile ---
# Use `dev` locally, `prod` on Railway.
SPRING_PROFILES_ACTIVE=dev

# --- Supabase (Postgres) — filled in during Step 2 of the takeover roadmap ---
# Example: jdbc:postgresql://db.xxxxxxxxxxxx.supabase.co:5432/postgres
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- ToyyibPay (mock in dev; real keys in Step 4+) ---
TOYYIBPAY_API_KEY=
TOYYIBPAY_CATEGORY_CODE=

# --- Admin (placeholder — Spring Security hardening pass after Step 3) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
